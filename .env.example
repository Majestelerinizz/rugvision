# Veritabani (Neon PostgreSQL)
DATABASE_URL="postgresql://KULLANICI:SIFRE@HOST/neondb?sslmode=require"

# Auth — EN AZ 32 karakter (kisa olursa uygulama baslamaz)
JWT_SECRET="uzun-rastgele-deger-uretin-node-crypto-ile"

# Depolama: local (dev/git deploy) | r2 | s3
STORAGE_DRIVER="local"

