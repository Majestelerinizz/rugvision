    {
      "name": "Rugs Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('rugId', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"sku\": \"SKU-{{$timestamp}}\",\n  \"slug\": \"modern-rug-{{$timestamp}}\",\n  \"name\": \"Modern Halı\",\n  \"widthCm\": 160,\n  \"lengthCm\": 230,\n  \"price\": 4999,\n  \"colors\": [\"bej\", \"gri\"],\n  \"category\": \"Salon\",\n  \"brand\": \"RugVision\",\n  \"description\": \"MVP test halisi\",\n  \"status\": \"ACTIVE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rugs",
          "host": ["{{baseUrl}}"],
          "path": ["rugs"]
        }
      }
    },
    {
      "name": "Rugs List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/rugs?merchantId={{merchantId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rugs"],
          "query": [
            { "key": "merchantId", "value": "{{merchantId}}" }
          ]
        }
      }
    },
    {
      "name": "Rugs Get By Id",
      "request": {
        "method": "GET",
