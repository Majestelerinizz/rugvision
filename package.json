{
  "name": "rugvision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/slug.test.ts tests/domain.test.ts tests/rate-limit.test.ts tests/auth.test.ts tests/storage.test.ts tests/subscription.test.ts tests/ai-detection.test.ts tests/device-ar.test.ts tests/model-urls.test.ts",
    "db:deploy": "prisma migrate deploy",
    "models:batch": "node scripts/batch-generate-rugs.mjs",
    "models:one": "node scripts/batch-generate-rugs.mjs --sku",
    "models:attach": "tsx scripts/attach-rug-models.ts",
    "models:upload-r2": "node --env-file=.env scripts/upload-models-r2.mjs",
    "photos:clean": "node scripts/clean-rug-photos.mjs",
    "reports:ar-acceptance": "node scripts/generate-ar-acceptance-report.mjs",
    "models:qa": "node scripts/qa-rug-models.mjs",
    "rugs:import": "tsx --env-file=.env scripts/import-rugs-from-csv.ts",
    "rugs:embed-codes": "node scripts/generate-embed-snippets.mjs",
    "rugs:onboard": "npm run rugs:import && npm run photos:clean && npm run models:batch && npm run models:upload-r2 && npm run models:attach",
    "perf:check": "node scripts/perf-check.mjs",
    "tunnel": "node scripts/tunnel.mjs",
    "dev:all": "concurrently -n dev,tunnel -c blue,magenta \"npm:dev\" \"npm:tunnel\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
