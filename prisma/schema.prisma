generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  MERCHANT
  STAFF
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum RugStatus {
  ACTIVE
  PASSIVE
}

enum AnalyticsEventType {
  WIDGET_OPENED
  AR_STARTED
  VIEW_3D
  PRODUCT_VIEWED
  ADDED_TO_CART
  PURCHASED
  SHARED
}

enum AiScanType {
  ROOM_DETECTION
  FLOOR_DETECTION
  COLOR_MATCH
  RECOMMENDATION
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  fullName     String
  role         UserRole
  merchantId   String?
  merchant     Merchant?        @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  staffProfile StaffMember?
  analytics    AnalyticsEvent[]
  apiKeys      ApiKey[]

  @@map("users")
}

model Merchant {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  logoUrl         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  staffMembers    StaffMember[]
  rugs            Rug[]
  widgetSettings  WidgetSettings?
  subscription    Subscription?
  analyticsEvents AnalyticsEvent[]
  domains         Domain[]
  apiKeys         ApiKey[]
  aiScans         AiScan[]

  @@map("merchants")
}

model StaffMember {
  id         String   @id @default(cuid())
  userId     String   @unique
  merchantId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("staff_members")
}

model Subscription {
  id           String             @id @default(cuid())
  merchantId   String             @unique
  plan         SubscriptionPlan
  status       SubscriptionStatus
  productLimit Int
  priceMonthly Int
  currentStart DateTime
  currentEnd   DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  merchant     Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Rug {
  id          String           @id @default(cuid())
  merchantId  String
  sku         String
  slug        String
  name        String
  category    String?
  brand       String?
  description String?
  widthCm     Int
  lengthCm    Int
  price       Decimal          @db.Decimal(12, 2)
  colors      String[]
  coverImage  String?
  model3dUrl  String?
  status      RugStatus        @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  merchant    Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  analytics   AnalyticsEvent[]

  @@unique([merchantId, sku])
  @@unique([merchantId, slug])
  @@index([merchantId])
  @@map("rugs")
}

model WidgetSettings {
  id           String   @id @default(cuid())
  merchantId   String   @unique
  buttonColor  String?  @default("#111827")
  buttonText   String?  @default("Odamda Gor")
  borderRadius Int?     @default(9999)
  logoUrl      String?
  darkMode     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("widget_settings")
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  merchantId String
  rugId      String?
  userId     String?
  eventType  AnalyticsEventType
  metadata   Json?
  occurredAt DateTime           @default(now())
  merchant   Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rug        Rug?               @relation(fields: [rugId], references: [id], onDelete: SetNull)
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([merchantId, eventType, occurredAt])
  @@index([rugId])
  @@map("analytics_events")
}

model Domain {
  id         String   @id @default(cuid())
  merchantId String
  host       String
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, host])
  @@index([host])
  @@map("domains")
}

model ApiKey {
  id         String    @id @default(cuid())
  merchantId String?
  userId     String?
  keyHash    String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  merchant   Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([userId])
  @@map("api_keys")
}

model AiScan {
  id            String     @id @default(cuid())
  merchantId    String
  rugId         String?
  scanType      AiScanType
  inputImageUrl String?
  result        Json?
  createdAt     DateTime   @default(now())
  merchant      Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, scanType, createdAt])
  @@map("ai_scans")
}
